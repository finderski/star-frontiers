  "compatibility": {
    "minimum": 14,
    "verified": 14
  },
  "authors": [
    {
      "name": "Local development"
    }
  ],
  "esmodules": [
    "star-frontiers.mjs"
  ],
  "styles": [
    "styles/star-frontiers.css"
