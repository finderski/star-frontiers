{
  "id": "star-frontiers",
  "title": "Star Frontiers (Alpha Dawn)",
  "description": "A Foundry VTT v14 system for Star Frontiers: Alpha Dawn, starting with Basic Rules support and reserving hooks for Expanded Rules.",
  "version": "0.1.0",
  "url": "https://github.com/finderski/star-frontiers",
  "manifest": "https://raw.githubusercontent.com/finderski/star-frontiers/main/system.json",
