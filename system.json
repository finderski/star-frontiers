{
  "id": "star-frontiers",
  "title": "Star Frontiers",
  "description": "A Foundry VTT system for building out Star Frontiers character sheets and rules support.",
  "version": "0.1.0",
  "compatibility": {
    "minimum": 14,
    "verified": 14
  },
  "authors": [
    {
      "name": "Local development"
    }
  ],
  "esmodules": [
    "star-frontiers.mjs"
  ],
  "styles": [
    "styles/star-frontiers.css"
