<section class="star-frontiers-sheet {{themeClass}}" autocomplete="off">
  <header class="sheet-header paper-header">
    <div class="player-name-row">
      <label class="field-line player-name">
        <span>{{localize "STARFRONTIERS.Character.PlayerName"}}</span>
        <input type="text" name="system.playerName" value="{{system.playerName}}" />
      </label>
      <button type="button" data-action="generateStats" title="{{localize generateStatsLabel}}">
        <i class="fa-solid fa-dice-d10"></i>
        <span>{{localize generateStatsLabel}}</span>
      </button>
    </div>
    <div class="identity-block">
      <!-- Player Name Row was here -->
      <label class="field-line">
        <span>{{localize "STARFRONTIERS.Character.CharacterName"}}</span>
        <input type="text" name="name" value="{{actor.name}}" />
      </label>
      <label class="field-line">
        <span>{{localize "STARFRONTIERS.Character.Handedness"}}</span>
        <select name="system.handedness.kind">
          {{selectOptions handednessChoices selected=handednessKind localize=true}}
        </select>
      </label>
      <div class="movement-row">
        <label class="field-line">
          <span>{{localize "STARFRONTIERS.Character.Walking"}}</span>
          <span class="input-with-unit">
          <span class="readonly-value">{{system.derived.walking}}</span>
          <span class="unit">{{localize "STARFRONTIERS.Character.meter-abbr"}}</span>
        </span>
        </label>
        <label class="field-line">
          <span>{{localize "STARFRONTIERS.Character.Running"}}</span>
          <span class="input-with-unit">
          <span class="readonly-value">{{system.derived.running}}</span>
          <span class="unit">{{localize "STARFRONTIERS.Character.meter-abbr"}}</span>
        </span>
        </label>
      </div>
    </div>

    <div class="identity-block compact">
      <label class="field-line">
        <span>{{localize "STARFRONTIERS.Character.Race"}}</span>
        <input type="text" name="system.race" value="{{system.race}}" />
      </label>
      <label class="field-line">
        <span>{{localize "STARFRONTIERS.Character.Sex"}}</span>
        <input type="text" name="system.sex" value="{{system.sex}}" />
      </label>
      <label class="field-line">
        <span>{{localize "STARFRONTIERS.Character.Hourly"}}</span>
        <span class="input-with-unit">
          <span class="readonly-value">{{system.derived.hourly}}</span>
          <span class="unit">{{localize "STARFRONTIERS.Character.kilometer-abbr"}}</span>
        </span>
      </label>
    </div>
  </header>

  <nav class="sheet-tabs" role="tablist" aria-label="{{localize "STARFRONTIERS.Character.PhysicalData"}}">
    <button type="button" class="sheet-tab" role="tab" data-tab="profile" title="{{localize "STARFRONTIERS.Character.TabProfile"}}" aria-label="{{localize "STARFRONTIERS.Character.TabProfile"}}">
      <span class="sheet-tab-icon" style="-webkit-mask-image: url('systems/star-frontiers/assets/images/sheet-icons/profile.svg'); mask-image: url('systems/star-frontiers/assets/images/sheet-icons/profile.svg');"></span>
    </button>
    <button type="button" class="sheet-tab" role="tab" data-tab="skills-equipment" title="{{localize "STARFRONTIERS.Character.TabSkillsEquipment"}}" aria-label="{{localize "STARFRONTIERS.Character.TabSkillsEquipment"}}">
      <span class="sheet-tab-icon" style="-webkit-mask-image: url('systems/star-frontiers/assets/images/sheet-icons/skill_tree.svg'); mask-image: url('systems/star-frontiers/assets/images/sheet-icons/skill_tree.svg');"></span>
    </button>
    <button type="button" class="sheet-tab" role="tab" data-tab="notes" title="{{localize "STARFRONTIERS.Character.TabNotes"}}" aria-label="{{localize "STARFRONTIERS.Character.TabNotes"}}">
      <span class="sheet-tab-icon" style="-webkit-mask-image: url('systems/star-frontiers/assets/images/sheet-icons/memory.svg'); mask-image: url('systems/star-frontiers/assets/images/sheet-icons/memory.svg');"></span>
    </button>
  </nav>

  <main class="sheet-tabs-content">
    <div class="sheet-tab-panel" data-tab-panel="profile" role="tabpanel">
    <fieldset class="paper-box physical-data">
      <legend>{{localize "STARFRONTIERS.Character.PhysicalData"}}</legend>
      <div class="paired-stat">
        <div class="roll-label-pair">
          <div class="roll-label-group roll-label-group--left">
            <button type="button" class="roll-label-main" data-action="rollAbility" data-ability="str" title="{{localize "STARFRONTIERS.Character.RollAbilityPublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Ability.str"}}</span></button>
            <div class="roll-label-actions">
              <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollAbility" data-ability="str" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollAbilityBlind"}}"></button>
              <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollAbility" data-ability="str" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollAbilityWhisper"}}"></button>
            </div>
          </div>
          <span class="slash">/</span>
          <div class="roll-label-group roll-label-group--right">
            <button type="button" class="roll-label-main" data-action="rollAbility" data-ability="sta" title="{{localize "STARFRONTIERS.Character.RollAbilityPublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Ability.sta"}}</span></button>
            <div class="roll-label-actions">
              <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollAbility" data-ability="sta" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollAbilityBlind"}}"></button>
              <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollAbility" data-ability="sta" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollAbilityWhisper"}}"></button>
            </div>
          </div>
        </div>
        <input type="number" name="system.abilities.str.value" value="{{system.abilities.str.value}}" min="1" max="100" />
        <span class="slash">/</span>
        <input type="number" name="system.abilities.sta.value" value="{{system.abilities.sta.value}}" min="1" max="100" />
      </div>
      <div class="paired-stat">
        <div class="roll-label-pair">
          <div class="roll-label-group roll-label-group--left">
            <button type="button" class="roll-label-main" data-action="rollAbility" data-ability="dex" title="{{localize "STARFRONTIERS.Character.RollAbilityPublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Ability.dex"}}</span></button>
            <div class="roll-label-actions">
              <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollAbility" data-ability="dex" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollAbilityBlind"}}"></button>
              <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollAbility" data-ability="dex" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollAbilityWhisper"}}"></button>
            </div>
          </div>
          <span class="slash">/</span>
          <div class="roll-label-group roll-label-group--right">
            <button type="button" class="roll-label-main" data-action="rollAbility" data-ability="rs" title="{{localize "STARFRONTIERS.Character.RollAbilityPublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Ability.rs"}}</span></button>
            <div class="roll-label-actions">
              <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollAbility" data-ability="rs" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollAbilityBlind"}}"></button>
              <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollAbility" data-ability="rs" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollAbilityWhisper"}}"></button>
            </div>
          </div>
        </div>
        <input type="number" name="system.abilities.dex.value" value="{{system.abilities.dex.value}}" min="1" max="100" />
        <span class="slash">/</span>
        <input type="number" name="system.abilities.rs.value" value="{{system.abilities.rs.value}}" min="1" max="100" />
      </div>
      <div class="paired-stat">
        <div class="roll-label-pair">
          <div class="roll-label-group roll-label-group--left">
            <button type="button" class="roll-label-main" data-action="rollAbility" data-ability="int" title="{{localize "STARFRONTIERS.Character.RollAbilityPublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Ability.int"}}</span></button>
            <div class="roll-label-actions">
              <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollAbility" data-ability="int" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollAbilityBlind"}}"></button>
              <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollAbility" data-ability="int" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollAbilityWhisper"}}"></button>
            </div>
          </div>
          <span class="slash">/</span>
          <div class="roll-label-group roll-label-group--right">
            <button type="button" class="roll-label-main" data-action="rollAbility" data-ability="log" title="{{localize "STARFRONTIERS.Character.RollAbilityPublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Ability.log"}}</span></button>
            <div class="roll-label-actions">
              <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollAbility" data-ability="log" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollAbilityBlind"}}"></button>
              <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollAbility" data-ability="log" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollAbilityWhisper"}}"></button>
            </div>
          </div>
        </div>
        <input type="number" name="system.abilities.int.value" value="{{system.abilities.int.value}}" min="1" max="100" />
        <span class="slash">/</span>
        <input type="number" name="system.abilities.log.value" value="{{system.abilities.log.value}}" min="1" max="100" />
      </div>
      <div class="paired-stat">
        <div class="roll-label-pair">
          <div class="roll-label-group roll-label-group--left">
            <button type="button" class="roll-label-main" data-action="rollAbility" data-ability="per" title="{{localize "STARFRONTIERS.Character.RollAbilityPublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Ability.per"}}</span></button>
            <div class="roll-label-actions">
              <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollAbility" data-ability="per" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollAbilityBlind"}}"></button>
              <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollAbility" data-ability="per" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollAbilityWhisper"}}"></button>
            </div>
          </div>
          <span class="slash">/</span>
          <div class="roll-label-group roll-label-group--right">
            <button type="button" class="roll-label-main" data-action="rollAbility" data-ability="ldr" title="{{localize "STARFRONTIERS.Character.RollAbilityPublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Ability.ldr"}}</span></button>
            <div class="roll-label-actions">
              <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollAbility" data-ability="ldr" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollAbilityBlind"}}"></button>
              <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollAbility" data-ability="ldr" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollAbilityWhisper"}}"></button>
            </div>
          </div>
        </div>
        <input type="number" name="system.abilities.per.value" value="{{system.abilities.per.value}}" min="1" max="100" />
        <span class="slash">/</span>
        <input type="number" name="system.abilities.ldr.value" value="{{system.abilities.ldr.value}}" min="1" max="100" />
      </div>
      <div class="single-stat">
        <div class="roll-label-group roll-label-group--left">
          <button type="button" class="roll-label-main" data-action="rollInitiative" title="{{localize "STARFRONTIERS.Character.RollInitiativePublic"}}"><i class="fa-solid fa-dice-d10 roll-label-main__icon" aria-hidden="true"></i><span class="roll-label-main__text">{{localize "STARFRONTIERS.Character.InitiativeModifier-abbr"}}</span></button>
          <div class="roll-label-actions">
            <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollInitiative" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollInitiativeBlind"}}"></button>
            <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollInitiative" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollInitiativeWhisper"}}"></button>
          </div>
        </div>
        <input type="number" value="{{system.derived.initiativeMod}}" readonly />
      </div>
    </fieldset>

    <fieldset class="paper-box medical-record">
      <legend>{{localize "STARFRONTIERS.Character.MedicalRecord"}}</legend>
      <label>
        <span class="labelSpan">{{localize "STARFRONTIERS.Character.CurrentSta"}}</span>
        <input class="fieldInput" type="number" name="system.stamina.value" value="{{system.stamina.value}}" />
      </label>
      <label class="stacked">
        <span class="labelSpan">{{localize "STARFRONTIERS.Character.OtherInjuries"}}</span>
      </label>
      <prose-mirror
            name="system.personalFile.injuries"
            data-document-u-u-i-d="{{actor.uuid}}"
            value="{{system.personalFile.injuries}}"
            collaborate="false"
            toggled="true"
          >
            {{{enrichedPersonalInjuries}}}
      </prose-mirror>
    </fieldset>

    <fieldset class="paper-box weapons-box full-width">
      <legend>{{localize "STARFRONTIERS.Character.Weapons"}}</legend>
      <div class="weapons-grid weapons-heading" aria-hidden="true">
        <span class="labelSpan ls-Left">{{localize "STARFRONTIERS.Weapon.Name"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Weapon.Damage"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Weapon.BasicToHit"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Weapon.PointBlank-abbr"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Weapon.Short-abbr"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Weapon.Medium-abbr"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Weapon.Long-abbr"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Weapon.Extreme-abbr"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Weapon.Ammo"}}</span>
        <span class="labelSpan ls-Center">{{localize "STARFRONTIERS.Item.Actions"}}</span>
      </div>
      {{#each weaponRows as |row|}}
        <div class="weapons-grid" data-item-id="{{row.key}}">
          {{#if row.editable}}
            <div class="roll-label-group">
              <button type="button" class="weapon-roll-button" data-action="rollWeaponAttack" title="{{localize "STARFRONTIERS.Weapon.RollAttack"}}">{{row.data.name}}</button>
              <div class="roll-label-actions">
                <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollWeaponAttack" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Weapon.RollAttackBlind"}}"></button>
                <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollWeaponAttack" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Weapon.RollAttackWhisper"}}"></button>
              </div>
            </div>
            <div class="roll-label-group">
                {{#if row.data.hasDamage}}
                  <button type="button" class="weapon-roll-button weapon-roll-button--damage" data-action="rollWeaponDamage" title="{{localize "STARFRONTIERS.Weapon.RollDamage"}}">{{row.data.damage}}</button>
                  <div class="roll-label-actions">
                    <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollWeaponDamage" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Weapon.RollDamageBlind"}}"></button>
                    <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollWeaponDamage" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Weapon.RollDamageWhisper"}}"></button>
                  </div>
                {{else}}
                  <span class="weapon-roll-button weapon-roll-button--damage weapon-roll-button--empty">{{row.data.damage}}</span>
                {{/if}}
            </div>
          {{else}}
            <input type="text" value="{{row.data.name}}" aria-label="{{localize "STARFRONTIERS.Weapon.Name"}}" readonly />
            <input type="text" value="{{row.data.damage}}" aria-label="{{localize "STARFRONTIERS.Weapon.Damage"}}" readonly />
          {{/if}}
          <input class="ls-Center" type="text" value="{{row.data.toHit}}" aria-label="{{localize "STARFRONTIERS.Weapon.BasicToHit"}}" readonly />
          <input class="ls-Center" type="text" value="{{row.data.pointBlank}}" aria-label="PB" readonly />
          <input class="ls-Center" type="text" value="{{row.data.short}}" aria-label="S" readonly />
          <input class="ls-Center" type="text" value="{{row.data.medium}}" aria-label="M" readonly />
          <input class="ls-Center" type="text" value="{{row.data.long}}" aria-label="L" readonly />
          <input class="ls-Center" type="text" value="{{row.data.extreme}}" aria-label="E" readonly />
          {{#if row.editable}}
            {{#if row.data.hasAmmo}}
              <div class="weapon-ammo-cell">
                {{#if row.data.isSEU}}
                  <div class="battery-icon" style="-webkit-mask-image: url('systems/star-frontiers/{{row.data.batteryIcon}}'); mask-image: url('systems/star-frontiers/{{row.data.batteryIcon}}');"></div>
                  <input type="number" value="{{row.data.ammoLoaded}}" min="0" max="{{row.data.ammoCapacity}}" data-item-ammo-loaded aria-label="{{localize "STARFRONTIERS.Item.Loaded"}}" />
                {{else}}
                  <input type="number" value="{{row.data.ammoLoaded}}" min="0" max="{{row.data.ammoCapacity}}" data-item-ammo-loaded aria-label="{{localize "STARFRONTIERS.Item.Loaded"}}" />
                  <span class="ammo-sep">/</span>
                  <span class="ammo-cap">{{row.data.ammoCapacity}}</span>
                {{/if}}
              </div>
            {{else}}
              <div class="weapon-ammo-cell"></div>
            {{/if}}
          {{else}}
            <div class="weapon-ammo-cell"></div>
          {{/if}}
          {{#if row.editable}}
            <div class="item-actions">
              <button type="button" class="weapon-carry-state weapon-carry-state--{{row.data.carryState}}" data-action="cycleCarryState" title="{{localize "STARFRONTIERS.Item.CarryState"}}" aria-label="{{localize "STARFRONTIERS.Item.CarryState"}}"></button>
              <div class="weapon-gear-wrap">
                <button type="button" class="weapon-row-action weapon-gear-btn" data-action="toggleWeaponGear" title="{{localize "STARFRONTIERS.Weapon.Configure"}}">
                  <i class="fa-solid fa-gear"></i>
                </button>
                <div class="weapon-gear-panel">
                  <button type="button" data-action="openItem" title="{{localize "STARFRONTIERS.Item.Open"}}">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </button>
                  {{#if row.data.hasModes}}
                    <label class="seu-dial-label weapon-mode-selector">
                      <span>{{localize "STARFRONTIERS.Weapon.Mode.Label"}}</span>
                      <select data-action="setWeaponMode" aria-label="{{localize "STARFRONTIERS.Weapon.Mode.Label"}}">
                        {{#each row.data.modes as |mode|}}
                          <option value="{{mode.key}}" {{#if mode.isActive}}selected{{/if}}>{{mode.label}}</option>
                        {{/each}}
                      </select>
                    </label>
                  {{/if}}
                  {{#if row.data.hasAmmo}}
                    <label class="seu-dial-label">
                      <span>{{localize "STARFRONTIERS.Item.LinkedAmmo"}}</span>
                      <select data-item-field="system.ammo.clipItem" aria-label="{{localize "STARFRONTIERS.Item.LinkedAmmo"}}">
                        <option value="">—</option>
                        {{#each row.data.clipChoices as |group|}}
                          <optgroup label="{{group.group}}">
                            {{#each group.options as |option|}}
                              <option value="{{option.id}}" {{#if option.selected}}selected{{/if}}>{{option.name}}</option>
                            {{/each}}
                          </optgroup>
                        {{/each}}
                      </select>
                    </label>
                  {{/if}}
                  {{#if row.data.canReload}}
                    <button type="button" data-action="reloadWeapon" title="{{localize "STARFRONTIERS.Weapon.Reload"}}">
                      <i class="fa-solid fa-rotate-right"></i>
                    </button>
                  {{/if}}
                  <label class="seu-dial-label">
                    <span>{{localize "STARFRONTIERS.Item.Quantity"}}</span>
                    <input type="number" class="seu-dial" min="0" step="1" value="{{row.data.quantity}}" data-item-field="system.quantity" aria-label="{{localize "STARFRONTIERS.Item.Quantity"}}" />
                  </label>
                  {{#if row.data.isSEU}}
                    <label class="seu-dial-label">
                      <span>{{localize "STARFRONTIERS.Item.CurrentSetting"}}</span>
                      <input type="number" class="seu-dial" min="{{row.data.seuMin}}" max="{{row.data.seuMax}}" value="{{row.data.seuCurrent}}" data-item-seu-dial aria-label="{{localize "STARFRONTIERS.Item.CurrentSetting"}}" />
                    </label>
                  {{/if}}
                </div>
              </div>
              <button type="button" class="weapon-row-action" data-action="deleteItem" title="{{localize "STARFRONTIERS.Item.Delete"}}">
                <i class="fa-solid fa-trash"></i>
              </button>
            </div>
          {{else}}
            <button type="button" data-action="placeholder" data-label="{{localize "STARFRONTIERS.Weapon.Attack"}}" title="{{localize "STARFRONTIERS.Placeholder.Action"}}">
              <i class="fa-solid fa-crosshairs"></i>
            </button>
          {{/if}}
        </div>
      {{/each}}
      <div class="section-controls">
        <button type="button" data-action="createItem" data-type="weapon" data-name="{{localize "STARFRONTIERS.Item.NewWeapon"}}" title="{{localize "STARFRONTIERS.Character.AddWeapon"}}">
          <i class="fa-solid fa-plus"></i>
          <span>{{localize "STARFRONTIERS.Character.AddWeapon"}}</span>
        </button>
      </div>
    </fieldset>

    <div class="left-column">
      <fieldset class="paper-box defenses-box">
        <legend>{{localize "STARFRONTIERS.Character.Defenses"}}</legend>
        <fieldset class="paper-box defenses-box worn-defenses">
          <legend>{{localize "STARFRONTIERS.Character.WornDefenses"}}</legend>
          <div class="defense-slot" data-defense-slot="suit">
            <span class="defense-slot__label">{{localize "STARFRONTIERS.Character.Suit"}}</span>
            {{#if wornSuit}}
              <button type="button" class="defense-slot__chip" data-action="openItem" data-item-id="{{wornSuit.id}}" data-item-drag="true" draggable="true" title="{{localize "STARFRONTIERS.Item.Open"}}">{{wornSuit.name}}</button>
              <button type="button" class="defense-slot__clear" data-action="clearDefenseSlot" data-slot="suit" title="{{localize "STARFRONTIERS.Character.RemoveWorn"}}" aria-label="{{localize "STARFRONTIERS.Character.RemoveWorn"}}"><i class="fa-solid fa-xmark"></i></button>
            {{else}}
              <span class="defense-slot__placeholder">{{localize "STARFRONTIERS.Character.DropArmorHere"}}</span>
            {{/if}}
          </div>
          <div class="defense-slot" data-defense-slot="screen">
            <span class="defense-slot__label">{{localize "STARFRONTIERS.Character.Screen"}}</span>
            {{#if wornScreen}}
              <button type="button" class="defense-slot__chip" data-action="openItem" data-item-id="{{wornScreen.id}}" data-item-drag="true" draggable="true" title="{{localize "STARFRONTIERS.Item.Open"}}">{{wornScreen.name}}</button>
              <button type="button" class="defense-slot__clear" data-action="clearDefenseSlot" data-slot="screen" title="{{localize "STARFRONTIERS.Character.RemoveWorn"}}" aria-label="{{localize "STARFRONTIERS.Character.RemoveWorn"}}"><i class="fa-solid fa-xmark"></i></button>
            {{else}}
              <span class="defense-slot__placeholder">{{localize "STARFRONTIERS.Character.DropScreenHere"}}</span>
            {{/if}}
          </div>
        </fieldset>
        <div class="defense-lists">
          <section class="stacked">
            <span>{{localize "STARFRONTIERS.Character.ArmorItems"}}</span>
            <div class="item-list compact-list">
              {{#each armorItems as |item|}}
                <div class="item-row" data-item-id="{{item.id}}">
                  <button type="button" class="item-name-button" data-action="openItem" data-item-drag="true" draggable="true" title="{{localize "STARFRONTIERS.Item.Open"}}">{{item.name}}</button>
                  <div class="item-actions">
                    <button type="button" class="weapon-carry-state weapon-carry-state--{{item.system.carryState}}" data-action="cycleCarryState" title="{{localize "STARFRONTIERS.Item.CarryState"}}" aria-label="{{localize "STARFRONTIERS.Item.CarryState"}}"></button>
                    <button type="button" data-action="deleteItem" title="{{localize "STARFRONTIERS.Item.Delete"}}"><i class="fa-solid fa-trash"></i></button>
                  </div>
                </div>
              {{/each}}
            </div>
            <div class="section-controls">
              <button type="button" data-action="createItem" data-type="armor" data-name="{{localize "STARFRONTIERS.Item.NewArmor"}}" title="{{localize "STARFRONTIERS.Character.AddArmor"}}">
                <i class="fa-solid fa-plus"></i>
                <span>{{localize "STARFRONTIERS.Character.AddArmor"}}</span>
              </button>
            </div>
          </section>
          <section class="stacked">
            <span>{{localize "STARFRONTIERS.Character.ScreenItems"}}</span>
            <div class="item-list compact-list">
              {{#each screenItems as |item|}}
                <div class="item-row" data-item-id="{{item.id}}">
                  <button type="button" class="item-name-button" data-action="openItem" data-item-drag="true" draggable="true" title="{{localize "STARFRONTIERS.Item.Open"}}">{{item.name}}</button>
                  <div class="item-actions">
                    <button type="button" class="weapon-carry-state weapon-carry-state--{{item.system.carryState}}" data-action="cycleCarryState" title="{{localize "STARFRONTIERS.Item.CarryState"}}" aria-label="{{localize "STARFRONTIERS.Item.CarryState"}}"></button>
                    <button type="button" data-action="deleteItem" title="{{localize "STARFRONTIERS.Item.Delete"}}"><i class="fa-solid fa-trash"></i></button>
                  </div>
                </div>
              {{/each}}
            </div>
            <div class="section-controls">
              <button type="button" data-action="createItem" data-type="screen" data-name="{{localize "STARFRONTIERS.Item.NewScreen"}}" title="{{localize "STARFRONTIERS.Character.AddScreen"}}">
                <i class="fa-solid fa-plus"></i>
                <span>{{localize "STARFRONTIERS.Character.AddScreen"}}</span>
              </button>
            </div>
          </section>
        </div>
      </fieldset>
    </div>

    <fieldset class="paper-box personal-file">
      <legend>{{localize "STARFRONTIERS.Character.PersonalFile"}}</legend>
      <div class="stacked">
        <span>{{localize "STARFRONTIERS.Character.RacialAbilities"}}</span>
        {{#if racialAbilityRows.length}}
          <div class="racial-ability-chip-list">
            {{#each racialAbilityRows as |row|}}
              <article class="racial-ability-chip" data-item-id="{{row.id}}">
                <div class="racial-ability-chip__header">
                  <button
                    type="button"
                    class="racial-ability-chip__name"
                    data-action="toggleRacialAbilityExpanded"
                    aria-expanded="false"
                    title="{{localize "STARFRONTIERS.Character.ToggleRacialAbilityDescription"}}"
                  >{{row.name}}</button>
                  {{#if row.isActiveRoll}}
                    <span class="racial-ability-chip__chance">{{row.currentChance}}% / {{row.cap}}%</span>
                  {{/if}}
                </div>
                {{#if row.description}}
                  <p class="racial-ability-chip__description">{{row.description}}</p>
                {{/if}}
                <div class="racial-ability-chip__footer">
                  {{#if row.hasEffect}}
                    <span class="racial-ability-chip__status{{#if row.effectActive}} racial-ability-chip__status--active{{/if}}">
                      {{row.effectStatusLabel}}
                    </span>
                  {{/if}}
                  <div class="item-actions racial-ability-chip__actions">
                    <div class="roll-label-group">
                      <button type="button" data-action="shareRacialAbility" title="{{localize "STARFRONTIERS.Character.ShareRacialAbilityPublic"}}">
                        <i class="fa-regular fa-comment-dots"></i>
                      </button>
                      <div class="roll-label-actions">
                        <button type="button" class="roll-label-action roll-label-action--blind" data-action="shareRacialAbility" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.ShareRacialAbilityBlind"}}"></button>
                        <button type="button" class="roll-label-action roll-label-action--gm" data-action="shareRacialAbility" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.ShareRacialAbilityWhisper"}}"></button>
                      </div>
                    </div>
                    {{#if row.isActiveRoll}}
                      <div class="roll-label-group">
                        <button type="button" data-action="rollRacialAbility" title="{{localize "STARFRONTIERS.Character.RollRacialAbilityPublic"}}">
                          <i class="fa-solid fa-dice-d10"></i>
                        </button>
                        <div class="roll-label-actions">
                          <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollRacialAbility" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollRacialAbilityBlind"}}"></button>
                          <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollRacialAbility" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollRacialAbilityWhisper"}}"></button>
                        </div>
                      </div>
                      <button type="button" data-action="decreaseRacialAbility" title="{{localize "STARFRONTIERS.Character.DecreaseRacialAbility"}}"{{#unless row.canDecrease}} disabled{{/unless}}>
                        <i class="fa-solid fa-minus"></i>
                      </button>
                      <button type="button" data-action="increaseRacialAbility" title="{{localize "STARFRONTIERS.Character.IncreaseRacialAbility"}}"{{#unless row.canIncrease}} disabled{{/unless}}>
                        <i class="fa-solid fa-plus"></i>
                      </button>
                    {{/if}}
                    {{#if row.hasEffect}}
                      <button type="button" class="racial-ability-effect-btn{{#if row.effectActive}} racial-ability-effect-btn--active{{/if}}" data-action="toggleRacialAbilityEffect" title="{{localize "STARFRONTIERS.Character.ToggleRacialEffect"}}">
                        <i class="fa-solid fa-fire-flame-curved"></i>
                      </button>
                    {{/if}}
                    <button type="button" data-action="openItem" title="{{localize "STARFRONTIERS.Character.OpenRacialAbility"}}">
                      <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                  </div>
                </div>
              </article>
            {{/each}}
          </div>
        {{/if}}
      </div>
      <div class="personal-file__experience">
        <label class="bigLabel">{{localize "STARFRONTIERS.Character.Experience"}}</label>
        <div class="fieldAndLabel">
          <input type="number" name="system.experience.earned" value="{{system.experience.earned}}" min="0" />
          <small>{{localize "STARFRONTIERS.Character.ExperienceAvailable"}}</small>
        </div>
        <span class="slash">/</span>
        <div class="fieldAndLabel">
          <input type="number" value="{{system.experience.spent}}" min="0" readonly />
          <small>{{localize "STARFRONTIERS.Character.ExperienceSpent"}}</small>
        </div>
        <!--
        <div class="personal-file__experience-grid">
          <label class="personal-file__experience-field">
            <input type="number" name="system.experience.earned" value="{{system.experience.earned}}" min="0" />
            <small>{{localize "STARFRONTIERS.Character.ExperienceAvailable"}}</small>
          </label>
          <label class="personal-file__experience-field">
            <input type="number" value="{{system.experience.spent}}" min="0" readonly />
            <small>{{localize "STARFRONTIERS.Character.ExperienceSpent"}}</small>
          </label>
        </div>
        -->
      </div>
      <label>
        <span>{{localize "STARFRONTIERS.Character.Credits"}}</span>
        <input type="number" name="system.credits" value="{{system.credits}}" min="0" />
      </label>
      <label>
        <span>{{localize "STARFRONTIERS.Character.PayPerDay"}}</span>
        <input type="number" name="system.pay.perDay" value="{{system.pay.perDay}}" min="0" />
      </label>
    </fieldset>

    </div>

    <div class="sheet-tab-panel skills-and-equipment" data-tab-panel="skills-equipment" role="tabpanel">
      {{#if expandedRules}}
        <fieldset class="paper-box skills-box">
          <legend>{{localize "STARFRONTIERS.Character.Skills"}}</legend>
          <div class="labelRow">
            <label class="field-line">{{localize "STARFRONTIERS.Character.CareerPrimarySkillArea-abbr"}}</label>
            <select class="borderlessInput" name="system.psa">
              {{selectOptions psaChoices selected=system.psa localize=true}}
            </select>
          </div>
          <div class="item-list">
            {{#each skillRows as |row|}}
              <div class="item-row skill-row{{#if row.isSubskill}} skill-row--subskill{{/if}}" data-item-id="{{row.id}}">
                <div class="roll-label-group">
                  <button type="button" class="item-name-button" data-action="rollSkill" data-item-drag="true" draggable="true" title="{{localize "STARFRONTIERS.Character.RollSkillPublic"}}">{{row.name}}</button>
                  <div class="roll-label-actions">
                    <button type="button" class="roll-label-action roll-label-action--blind" data-action="rollSkill" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Character.RollSkillBlind"}}"></button>
                    <button type="button" class="roll-label-action roll-label-action--gm" data-action="rollSkill" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Character.RollSkillWhisper"}}"></button>
                  </div>
                </div>
                {{#if row.isSubskill}}
                  <span></span>
                {{else}}
                  <input type="number" class="skill-level-input" min="0" max="6" step="1" value="{{row.level}}" data-item-field="system.level" aria-label="{{localize "STARFRONTIERS.Item.Level"}}" />
                {{/if}}
                <div class="item-actions">
                  <button type="button" data-action="openItem" title="{{localize "STARFRONTIERS.Item.Open"}}"><i class="fa-solid fa-pen-to-square"></i></button>
                  {{#unless row.isSubskill}}
                    <button type="button" data-action="deleteItem" title="{{localize "STARFRONTIERS.Item.Delete"}}"><i class="fa-solid fa-trash"></i></button>
                  {{/unless}}
                </div>
              </div>
            {{/each}}
          </div>
          <div class="section-controls">
            <button type="button" data-action="createItem" data-type="skill" data-name="{{localize "STARFRONTIERS.Item.NewSkill"}}" title="{{localize "STARFRONTIERS.Character.AddSkill"}}">
              <i class="fa-solid fa-plus"></i>
              <span>{{localize "STARFRONTIERS.Character.AddSkill"}}</span>
            </button>
          </div>
        </fieldset>
      {{/if}}

      <fieldset class="paper-box equipment-box">
        <legend>{{localize "STARFRONTIERS.Character.Equipment"}}</legend>
        <div class="equipment-header">
          <span>{{localize "STARFRONTIERS.Item.Name"}}</span>
          <span class="equipment-col--qty">{{localize "STARFRONTIERS.Item.Quantity"}}</span>
          <span class="equipment-col--mass">{{localize "STARFRONTIERS.Item.Mass"}}</span>
          <span class="equipment-col--actions">{{localize "STARFRONTIERS.Item.Actions"}}</span>
        </div>
        <div class="equipment-list">
          {{#each inventoryRows as |row|}}
            <div class="equipment-row" data-item-id="{{row.id}}" data-item-type="{{row.type}}">
              <div class="equipment-row__collapsed">
                <button type="button"
                        class="equipment-row__name"
                        data-action="{{#if row.expandable}}toggleEquipmentRow{{else}}openItem{{/if}}"
                        data-item-drag="true"
                        draggable="true"
                        title="{{#if row.expandable}}{{localize "STARFRONTIERS.Item.Expand"}}{{else}}{{localize "STARFRONTIERS.Item.Open"}}{{/if}}">
                  <span class="equipment-row__name-text">{{row.name}}</span>
                  {{#if row.statusBadge}}
                    <span class="equipment-row__badge">{{row.statusBadge}}</span>
                  {{/if}}
                  {{#if row.expandable}}
                    <i class="fa-solid fa-chevron-down equipment-row__chevron"></i>
                  {{/if}}
                </button>
                <span class="equipment-col--qty">
                  {{#if (eq row.quantity null)}}{{else}}
                    <input type="number" min="0" step="1" value="{{row.quantity}}" data-item-field="system.quantity" aria-label="{{localize "STARFRONTIERS.Item.Quantity"}}" />
                  {{/if}}
                </span>
                <span class="equipment-col--mass">
                  {{#if (eq row.mass null)}}—{{else}}{{row.mass}}{{/if}}
                </span>
                <div class="equipment-col--actions item-actions">
                  {{#if row.carryStateCycleable}}
                    <button type="button" class="weapon-carry-state weapon-carry-state--{{row.carryState}}" data-action="cycleCarryState" title="{{row.carryStateLabel}}" aria-label="{{row.carryStateLabel}}"></button>
                  {{else}}
                    {{#if row.carryStateLocked}}
                      <button type="button" class="weapon-carry-state weapon-carry-state--stored" disabled title="{{row.carryStateLabel}}" aria-label="{{row.carryStateLabel}}"></button>
                    {{/if}}
                  {{/if}}
                  <button type="button" data-action="deleteItem" title="{{localize "STARFRONTIERS.Item.Delete"}}"><i class="fa-solid fa-trash"></i></button>
                </div>
              </div>

              {{#if row.expandable}}
                <div class="equipment-row__expanded" hidden>
                  <div class="equipment-row__expanded-header">
                    <button type="button" class="equipment-row__edit" data-action="openItem" title="{{localize "STARFRONTIERS.Item.Open"}}">
                      <i class="fa-solid fa-pen-to-square"></i>
                      <span>{{localize "STARFRONTIERS.Item.Edit"}}</span>
                    </button>
                  </div>
                  {{#if (eq row.type "consumable")}}
                    <div class="equipment-expanded__consumable">
                      <label>
                        <span>{{localize "STARFRONTIERS.Item.Uses"}}</span>
                        <input type="number" min="0" value="{{row.uses.value}}" data-item-field="system.uses.value" />
                        <span>/</span>
                        <input type="number" min="0" value="{{row.uses.max}}" data-item-field="system.uses.max" />
                      </label>
                      {{#if row.linkedRequiredSkillName}}
                        <label>
                          <span>{{localize "STARFRONTIERS.Item.RequiredSkill"}}</span>
                          <span>{{row.linkedRequiredSkillName}}</span>
                        </label>
                      {{/if}}
                      {{#if row.hasUseButton}}
                        <div class="roll-label-group">
                          <button type="button" class="sf-use-button" data-action="useConsumable" title="{{localize "STARFRONTIERS.Item.UsePublic"}}">
                            <i class="fa-solid fa-syringe"></i>
                            <span>{{localize "STARFRONTIERS.Item.Use"}}</span>
                          </button>
                          <div class="roll-label-actions">
                            <button type="button" class="roll-label-action roll-label-action--blind" data-action="useConsumable" data-roll-mode="blind" title="{{localize "STARFRONTIERS.Item.UseBlind"}}"></button>
                            <button type="button" class="roll-label-action roll-label-action--gm" data-action="useConsumable" data-roll-mode="gm" title="{{localize "STARFRONTIERS.Item.UseWhisper"}}"></button>
                          </div>
                        </div>
                      {{/if}}
                    </div>
                  {{/if}}

                  {{#if (eq row.type "powerSource")}}
                    <div class="equipment-expanded__powersource">
                      <label>
                        <span>{{localize "STARFRONTIERS.Item.SEURemaining"}}</span>
                        <input type="number" min="0" value="{{row.remaining.value}}" data-item-field="system.remaining" />
                        <span>/</span>
                        <span>{{row.remaining.max}}</span>
                      </label>
                    </div>
                  {{/if}}

                  {{#if (eq row.type "computer")}}
                    <div class="equipment-expanded__computer">
                      <label>
                        <span>{{localize "STARFRONTIERS.Item.FunctionPoints"}}</span>
                        <span>{{row.functionPoints.used}} / {{row.functionPoints.max}}</span>
                      </label>
                    </div>
                  {{/if}}

                  {{#if (eq row.type "ammo")}}
                    <div class="equipment-expanded__ammo">
                      <label>
                        <span>{{localize "STARFRONTIERS.Item.ShotsPerClip"}}</span>
                        <span>{{row.shots}}</span>
                      </label>
                    </div>
                  {{/if}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>

        {{#if hasAssets}}
          <div class="equipment-assets-separator">
            <span>{{localize "STARFRONTIERS.Character.Assets"}}</span>
          </div>
          <div class="equipment-list equipment-list--assets">
            {{#each assetRows as |row|}}
              <div class="equipment-row" data-item-id="{{row.id}}" data-item-type="{{row.type}}">
                <div class="equipment-row__collapsed">
                  <button type="button" class="equipment-row__name" data-action="openItem" title="{{localize "STARFRONTIERS.Item.Open"}}">
                    <span class="equipment-row__name-text">{{row.name}}</span>
                    {{#if row.statusBadge}}
                      <span class="equipment-row__badge">{{row.statusBadge}}</span>
                    {{/if}}
                  </button>
                  <span class="equipment-col--qty"></span>
                  <span class="equipment-col--mass">—</span>
                  <div class="equipment-col--actions item-actions">
                    <button type="button" data-action="deleteItem" title="{{localize "STARFRONTIERS.Item.Delete"}}"><i class="fa-solid fa-trash"></i></button>
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        {{/if}}

        <div class="section-controls">
          <div class="add-item-wrap">
            <button type="button" class="add-item-btn" data-action="toggleAddItemMenu" title="{{localize "STARFRONTIERS.Character.AddItem"}}">
              <i class="fa-solid fa-plus"></i>
              <span>{{localize "STARFRONTIERS.Character.AddItem"}}</span>
            </button>
            <div class="add-item-menu" hidden>
              <button type="button" data-action="createItem" data-type="gear" data-name="{{localize "STARFRONTIERS.Item.NewGear"}}" title="{{localize "STARFRONTIERS.Item.TypeLabels.gear"}}">
                <img src="systems/star-frontiers/assets/images/sheet-icons/light-backpack.svg" alt="" />
                <span>{{localize "STARFRONTIERS.Item.TypeLabels.gear"}}</span>
              </button>
              <button type="button" data-action="createItem" data-type="consumable" data-name="{{localize "STARFRONTIERS.Item.NewConsumable"}}" title="{{localize "STARFRONTIERS.Item.TypeLabels.consumable"}}">
                <i class="fa-solid fa-pills"></i>
                <span>{{localize "STARFRONTIERS.Item.TypeLabels.consumable"}}</span>
              </button>
              <button type="button" data-action="createItem" data-type="ammo" data-name="{{localize "STARFRONTIERS.Item.NewAmmo"}}" title="{{localize "STARFRONTIERS.Item.TypeLabels.ammo"}}">
                <img src="systems/star-frontiers/assets/images/sheet-icons/ammo-box.svg" alt="" />
                <span>{{localize "STARFRONTIERS.Item.TypeLabels.ammo"}}</span>
              </button>
              <button type="button" data-action="createItem" data-type="powerSource" data-name="{{localize "STARFRONTIERS.Item.NewPowerSource"}}" title="{{localize "STARFRONTIERS.Item.TypeLabels.powerSource"}}">
                <img src="systems/star-frontiers/assets/images/sheet-icons/power-generator.svg" alt="" />
                <span>{{localize "STARFRONTIERS.Item.TypeLabels.powerSource"}}</span>
              </button>
              <button type="button" data-action="createItem" data-type="computer" data-name="{{localize "STARFRONTIERS.Item.NewComputer"}}" title="{{localize "STARFRONTIERS.Item.TypeLabels.computer"}}">
                <img src="systems/star-frontiers/assets/images/sheet-icons/tablet.svg" alt="" />
                <span>{{localize "STARFRONTIERS.Item.TypeLabels.computer"}}</span>
              </button>
              <button type="button" data-action="createItem" data-type="program" data-name="{{localize "STARFRONTIERS.Item.NewProgram"}}" title="{{localize "STARFRONTIERS.Item.TypeLabels.program"}}">
                <img src="systems/star-frontiers/assets/images/sheet-icons/computing.svg" alt="" />
                <span>{{localize "STARFRONTIERS.Item.TypeLabels.program"}}</span>
              </button>
              <button type="button" data-action="createItem" data-type="vehicle" data-name="{{localize "STARFRONTIERS.Item.NewVehicle"}}" title="{{localize "STARFRONTIERS.Item.TypeLabels.vehicle"}}">
                <img src="systems/star-frontiers/assets/images/sheet-icons/steering-wheel.svg" alt="" />
                <span>{{localize "STARFRONTIERS.Item.TypeLabels.vehicle"}}</span>
              </button>
            </div>
          </div>
        </div>
        <div class="encumbrance-total{{#if encumbrance.encumbered}} encumbrance-total--encumbered{{/if}}" title="{{localize "STARFRONTIERS.Character.EncumbranceTooltip"}}">
          <span class="encumbrance-label">{{localize "STARFRONTIERS.Character.TotalMass"}}:</span>
          <span class="encumbrance-values">{{encumbrance.totalMass}} / {{encumbrance.threshold}} {{localize "STARFRONTIERS.Character.kilogram-abbr"}}</span>
          {{#if encumbrance.encumbered}}
            <span class="encumbrance-badge"><i class="fa-solid fa-weight-hanging"></i> {{localize "STARFRONTIERS.Character.Encumbered"}}</span>
          {{/if}}
        </div>
      </fieldset>
    </div>

    <div class="sheet-tab-panel" data-tab-panel="notes" role="tabpanel">
      <fieldset class="paper-box notes-box full-width">
        <legend>{{localize "STARFRONTIERS.Character.Notes"}}</legend>
        <prose-mirror
            name="system.personalFile.notes"
            data-document-u-u-i-d="{{actor.uuid}}"
            value="{{system.personalFile.notes}}"
            collaborate="false"
            toggled="true"
          >
            {{{enrichedPersonalNotes}}}
          </prose-mirror>
      </fieldset>

      {{#if expandedRules}}
        <fieldset class="paper-box expanded-rules full-width">
          <legend>{{localize "STARFRONTIERS.Character.ExpandedRules"}}</legend>
          <label class="stacked">
            <span>{{localize "STARFRONTIERS.Character.ExpandedNotes"}}</span>
            <textarea name="system.combatProfile.special">{{system.combatProfile.special}}</textarea>
          </label>
        </fieldset>
      {{/if}}
    </div>
  </main>
</section>
